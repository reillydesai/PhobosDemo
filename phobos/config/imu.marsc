component IMU {
    subcomponents{}
    parameters{
        bool accelerometer;
        bool gyro;
        bool magnetometer;
        bool orientation;
        int axisCount;
        int bus;
        int address;
        float rateHz;
    }
    functions{
        void init();
        float::m/s^2[] getAcceleration();
        float::rad/s[] getAngularVelocity();
        float[] getMagneticField();
        float[] getOrientation();
    }
}